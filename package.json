{
  "name": "bearsome",
  "version": "0.1.0",
  "description": "Bearsome — a friendly desktop app for gamers to find and install Minecraft mods from Modrinth.",
  "main": "out/main/index.js",
  "author": "Bearsome",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavel949/Bearsome.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.bearsome.app",
    "productName": "Bearsome",
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pavel949",
        "repo": "Bearsome"
      }
    ]
  }
}
